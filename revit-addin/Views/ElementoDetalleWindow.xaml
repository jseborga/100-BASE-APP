<Window x:Class="RvtConstructionOS.Views.ElementoDetalleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalle de Cómputos"
        Width="560" Height="720"
        MinWidth="420" MinHeight="500"
        WindowStartupLocation="Manual"
        ShowInTaskbar="False"
        Background="#F5F5F5"
        Closing="Window_Closing">

    <Window.Resources>
        <Style x:Key="SeccionHeader" TargetType="Border">
            <Setter Property="Background"   Value="#1F4E79"/>
            <Setter Property="Padding"      Value="10,5"/>
            <Setter Property="Margin"       Value="0,10,0,4"/>
        </Style>
        <Style x:Key="SeccionTxt" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="FontSize"     Value="11"/>
        </Style>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="#546E7A"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Val" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ValNum" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Foreground"   Value="#1F4E79"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="UnidLbl" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="#78909C"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="Margin"       Value="4,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><!-- Encabezado -->
            <RowDefinition Height="*"/>   <!-- Scroll contenido -->
            <RowDefinition Height="Auto"/><!-- Barra de estado match -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════ ENCABEZADO -->
        <Border Grid.Row="0" Background="#1A237E" Padding="14,10">
            <StackPanel>
                <TextBlock x:Name="txtTituloNombre"
                           Foreground="White" FontSize="14" FontWeight="Bold"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="txtTituloMeta"
                           Foreground="#90CAF9" FontSize="11" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════ CONTENIDO SCROLL -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="12,6,12,12">
            <StackPanel>

                <!-- ─── CANTIDADES BRUTAS ──────────────────────────────── -->
                <Border Style="{StaticResource SeccionHeader}">
                    <TextBlock Text="CANTIDADES DEL MODELO" Style="{StaticResource SeccionTxt}"/>
                </Border>

                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="22"/>
                        <RowDefinition Height="22"/>
                        <RowDefinition Height="22"/>
                        <RowDefinition Height="22"/>
                        <RowDefinition Height="22"/>
                        <RowDefinition Height="22"/>
                        <RowDefinition Height="22"/>
                        <RowDefinition Height="22"/>
                        <RowDefinition Height="22"/>
                    </Grid.RowDefinitions>

                    <!-- Instancias -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Instancias" Style="{StaticResource Lbl}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtInstancias" Style="{StaticResource ValNum}"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="und" Style="{StaticResource UnidLbl}"/>

                    <!-- Área bruta int -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Área bruta interior" Style="{StaticResource Lbl}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtAreaBrutaInt" Style="{StaticResource ValNum}"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="m²" Style="{StaticResource UnidLbl}"/>

                    <!-- Área bruta ext -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Área bruta exterior" Style="{StaticResource Lbl}"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtAreaBrutaExt" Style="{StaticResource ValNum}"/>
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="m²" Style="{StaticResource UnidLbl}"/>

                    <!-- Huecos -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Huecos descontados" Style="{StaticResource Lbl}"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtHuecos" Style="{StaticResource ValNum}" Foreground="#E53935"/>
                    <TextBlock Grid.Row="3" Grid.Column="2" Text="m²" Style="{StaticResource UnidLbl}"/>

                    <!-- Área neta int -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Área neta interior" Style="{StaticResource Lbl}" FontWeight="Bold"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="txtAreaNetaInt" Style="{StaticResource ValNum}" Foreground="#1B5E20" FontSize="13"/>
                    <TextBlock Grid.Row="4" Grid.Column="2" Text="m²" Style="{StaticResource UnidLbl}"/>

                    <!-- Volumen -->
                    <TextBlock Grid.Row="5" Grid.Column="0" x:Name="lblVolumen" Text="Volumen" Style="{StaticResource Lbl}"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" x:Name="txtVolumen" Style="{StaticResource ValNum}"/>
                    <TextBlock Grid.Row="5" Grid.Column="2" Text="m³" Style="{StaticResource UnidLbl}"/>

                    <!-- Longitud -->
                    <TextBlock Grid.Row="6" Grid.Column="0" x:Name="lblLongitud" Text="Longitud" Style="{StaticResource Lbl}"/>
                    <TextBlock Grid.Row="6" Grid.Column="1" x:Name="txtLongitud" Style="{StaticResource ValNum}"/>
                    <TextBlock Grid.Row="6" Grid.Column="2" Text="ml" Style="{StaticResource UnidLbl}"/>

                    <!-- Altura -->
                    <TextBlock Grid.Row="7" Grid.Column="0" x:Name="lblAltura" Text="Altura promedio" Style="{StaticResource Lbl}"/>
                    <TextBlock Grid.Row="7" Grid.Column="1" x:Name="txtAltura" Style="{StaticResource ValNum}"/>
                    <TextBlock Grid.Row="7" Grid.Column="2" Text="m" Style="{StaticResource UnidLbl}"/>

                    <!-- Espesor -->
                    <TextBlock Grid.Row="8" Grid.Column="0" x:Name="lblEspesor" Text="Espesor" Style="{StaticResource Lbl}"/>
                    <TextBlock Grid.Row="8" Grid.Column="1" x:Name="txtEspesor" Style="{StaticResource ValNum}"/>
                    <TextBlock Grid.Row="8" Grid.Column="2" Text="m" Style="{StaticResource UnidLbl}"/>
                </Grid>

                <!-- ─── SECCIÓN ESTRUCTURAL (acero) ────────────────────── -->
                <Border x:Name="borderSeccion" Style="{StaticResource SeccionHeader}" Visibility="Collapsed">
                    <TextBlock Text="SECCIÓN ESTRUCTURAL (ACERO)" Style="{StaticResource SeccionTxt}"/>
                </Border>
                <Grid x:Name="gridSeccion" Visibility="Collapsed" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="22"/>
                        <RowDefinition Height="22"/>
                        <RowDefinition Height="22"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Perfil" Style="{StaticResource Lbl}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtSeccion" Style="{StaticResource Val}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Peso lineal" Style="{StaticResource Lbl}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtPesoLineal" Style="{StaticResource ValNum}"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Peso total" Style="{StaticResource Lbl}" FontWeight="Bold"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtPesoTotal" Style="{StaticResource ValNum}" Foreground="#1B5E20" FontSize="13"/>
                </Grid>

                <!-- ─── CAPAS ESTRUCTURALES ─────────────────────────────── -->
                <Border x:Name="borderCapas" Style="{StaticResource SeccionHeader}" Visibility="Collapsed">
                    <TextBlock Text="CAPAS ESTRUCTURALES" Style="{StaticResource SeccionTxt}"/>
                </Border>
                <DataGrid x:Name="gridCapas" Visibility="Collapsed"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          RowHeight="22" FontSize="11" Margin="0,0,0,4"
                          Background="White" BorderBrush="#CFD8DC" BorderThickness="1"
                          ColumnHeaderHeight="24">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Función"   Binding="{Binding Funcion}"        Width="90"/>
                        <DataGridTextColumn Header="Material"  Binding="{Binding NombreMaterial}"  Width="*"/>
                        <DataGridTextColumn Header="e (m)"     Binding="{Binding EspesorM, StringFormat=F3}" Width="55"/>
                        <DataGridTextColumn Header="Área m²"   Binding="{Binding AreaM2, StringFormat=F2}"   Width="65"/>
                        <DataGridTextColumn Header="Vol m³"    Binding="{Binding VolumenM3, StringFormat=F3}" Width="60"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- ─── PARTIDAS ASIGNADAS ──────────────────────────────── -->
                <Border Style="{StaticResource SeccionHeader}">
                    <DockPanel>
                        <TextBlock Text="PARTIDAS ASIGNADAS" Style="{StaticResource SeccionTxt}" DockPanel.Dock="Left"/>
                        <Button x:Name="btnAgregarPartida" Content="+ Agregar"
                                DockPanel.Dock="Right" Margin="0,0,4,0"
                                FontSize="10" Padding="6,1" VerticalAlignment="Center"
                                Background="#42A5F5" Foreground="White" BorderThickness="0"
                                Cursor="Hand" Click="BtnAgregarPartida_Click"/>
                    </DockPanel>
                </Border>

                <ItemsControl x:Name="listPartidas" Margin="0,0,0,4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" BorderBrush="#CFD8DC" BorderThickness="1"
                                    CornerRadius="3" Margin="0,0,0,4" Padding="8,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Código + descripción -->
                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               FontWeight="SemiBold" FontSize="12"
                                               Text="{Binding Etiqueta}"
                                               TextTrimming="CharacterEllipsis"/>

                                    <!-- Botón quitar -->
                                    <Button Grid.Row="0" Grid.Column="1"
                                            Content="✕" Width="20" Height="20"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="#E53935" FontSize="11"
                                            Cursor="Hand" VerticalAlignment="Top"
                                            Tag="{Binding}"
                                            Click="BtnQuitarPartida_Click"/>

                                    <!-- Unidad + criterio -->
                                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="Unidad:" Foreground="#78909C" FontSize="10" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                        <ComboBox Tag="{Binding}" SelectionChanged="PartidaUnidad_Changed"
                                                  FontSize="11" Height="22" MinWidth="60"
                                                  x:Name="cmbPartidaUnidad">
                                            <ComboBoxItem Content="m2"/>
                                            <ComboBoxItem Content="m3"/>
                                            <ComboBoxItem Content="ml"/>
                                            <ComboBoxItem Content="und"/>
                                            <ComboBoxItem Content="kg"/>
                                            <ComboBoxItem Content="ton"/>
                                        </ComboBox>

                                        <TextBlock Text="Criterio:" Foreground="#78909C" FontSize="10" Margin="12,0,4,0" VerticalAlignment="Center"/>
                                        <ComboBox Tag="{Binding}" SelectionChanged="PartidaCriterio_Changed"
                                                  FontSize="11" Height="22" MinWidth="120">
                                            <ComboBoxItem Content="AREA_NETA_INT"/>
                                            <ComboBoxItem Content="AREA_NETA_EXT"/>
                                            <ComboBoxItem Content="AREA_BRUTA"/>
                                            <ComboBoxItem Content="VOLUMEN"/>
                                            <ComboBoxItem Content="LONGITUD"/>
                                            <ComboBoxItem Content="CANTIDAD"/>
                                            <ComboBoxItem Content="PESO"/>
                                        </ComboBox>

                                        <TextBlock Text="Factor:" Foreground="#78909C" FontSize="10" Margin="12,0,4,0" VerticalAlignment="Center"/>
                                        <TextBox Tag="{Binding}" Width="45" Height="22" FontSize="11"
                                                 Text="{Binding Factor, StringFormat=F2}"
                                                 LostFocus="PartidaFactor_LostFocus"/>

                                        <!-- Cantidad calculada -->
                                        <TextBlock Margin="12,0,0,0" FontSize="11" Foreground="#1B5E20" FontWeight="Bold" VerticalAlignment="Center">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="= {0:F3} {1}">
                                                    <Binding Path="Tag" RelativeSource="{RelativeSource AncestorType=Border}"/>
                                                    <Binding Path="UnidadElegida"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ─── CLASIFICACIÓN WBS / ODOO ────────────────────────── -->
                <Border Style="{StaticResource SeccionHeader}">
                    <TextBlock Text="CLASIFICACIÓN WBS / ODOO" Style="{StaticResource SeccionTxt}"/>
                </Border>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="22"/>
                        <RowDefinition Height="22"/>
                        <RowDefinition Height="22"/>
                        <RowDefinition Height="22"/>
                        <RowDefinition Height="22"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Keynote"     Style="{StaticResource Lbl}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtKeynote"  Style="{StaticResource Val}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Assembly Code" Style="{StaticResource Lbl}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtAssembly" Style="{StaticResource Val}"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Rubro Odoo"  Style="{StaticResource Lbl}"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtRubro"   Style="{StaticResource Val}"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Función"     Style="{StaticResource Lbl}"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtFuncion" Style="{StaticResource Val}"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Fase"        Style="{StaticResource Lbl}"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="txtFase"   Style="{StaticResource Val}"/>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══════════════════════════════════════════════════ BARRA MATCH -->
        <Border Grid.Row="2" x:Name="borderMatch"
                Padding="12,6" BorderThickness="0,1,0,0" BorderBrush="#CFD8DC">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Match: " Foreground="#546E7A" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtMatchEstado" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtMatchCriterio" Foreground="#78909C" FontSize="10"
                               Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Cerrar" Click="BtnCerrar_Click"
                        FontSize="11" Padding="12,4" Background="#546E7A"
                        Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </Grid>
        </Border>
    </Grid>
</Window>
